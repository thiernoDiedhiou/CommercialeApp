# Nom de l'application (affiché dans le footer du shop)
VITE_APP_NAME=Gestion Commerciale SaaS

# Domaine principal du SaaS (ex: votreapp.sn) — utilisé pour détecter les sous-domaines tenants
VITE_MAIN_DOMAIN=votreapp.sn

# URL du backend (proxied via Vite en dev, URL directe en prod)
VITE_API_URL=http://localhost

# api_key du tenant courant (remplacer par la vraie valeur depuis la DB)
VITE_TENANT_API_KEY=your_tenant_api_key_here
