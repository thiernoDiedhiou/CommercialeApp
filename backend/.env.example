# =============================================================================
# SAAS GESTION COMMERCIALE — Configuration d'environnement
# =============================================================================
# Copier ce fichier en .env et remplir les valeurs.
# Toutes les dépendances d'hébergement sont ici — zéro config dans le code.
# =============================================================================

APP_NAME="Gestion Commerciale SaaS"
APP_ENV=local             # local | staging | production
APP_KEY=                  # Généré via: php artisan key:generate
APP_DEBUG=true            # true en local, false en production
APP_URL=http://localhost:8000
APP_TIMEZONE=Africa/Dakar

# =============================================================================
# BASE DE DONNÉES
# Compatible: MySQL 8.0 (Hostinger, VPS, Docker)
# =============================================================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=saas_commercial
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# =============================================================================
# CACHE
# Options: file | database | redis | memcached | array
# Dev sans Redis  : file
# Production VPS  : redis
# Hostinger shared: database
# =============================================================================
CACHE_STORE=file
CACHE_PREFIX=saas_

# =============================================================================
# SESSION
# Options: file | cookie | database | redis | array
# Dev sans Redis  : file
# Production VPS  : redis
# Hostinger shared: database
# =============================================================================
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.votre-domaine.com

# =============================================================================
# FILE D'ATTENTE (QUEUE)
# Options: sync | database | redis | sqs
# sync: exécution immédiate sans worker (simple, Hostinger)
# redis: recommandé avec Laravel Horizon (VPS/Docker)
# =============================================================================
QUEUE_CONNECTION=database

# =============================================================================
# REDIS (si CACHE_STORE ou SESSION_DRIVER = redis)
# =============================================================================
REDIS_CLIENT=phpredis    # phpredis | predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# =============================================================================
# STOCKAGE FICHIERS
# Options: local | public | s3 | ftp | sftp
# local: stockage sur le serveur (Hostinger, VPS)
# s3:    compatible AWS S3, DigitalOcean Spaces, MinIO
# =============================================================================
FILESYSTEM_DISK=local

# Variables S3 (uniquement si FILESYSTEM_DISK=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=            # Pour MinIO ou DigitalOcean Spaces

# =============================================================================
# MAIL — SMTP global (fallback si le tenant n'a pas de SMTP configuré)
# Dev  : MAIL_MAILER=log  → emails dans storage/logs/laravel.log (pas d'envoi réel)
# Tests: MAIL_MAILER=array → capturés en mémoire (Mail::fake())
# Prod : Hostinger → MAIL_HOST=smtp.hostinger.com MAIL_PORT=587 MAIL_ENCRYPTION=tls
# =============================================================================
MAIL_MAILER=log
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=587
MAIL_USERNAME=noreply@votre-domaine.sn
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@votre-domaine.sn"
MAIL_FROM_NAME="${APP_NAME}"

# =============================================================================
# CORS — Origine autorisée pour le frontend
# En développement : http://localhost:5173 (Vite)
# En production    : https://votre-domaine.sn
# Utilisé par nginx pour le header Access-Control-Allow-Origin
# =============================================================================
CORS_ALLOWED_ORIGIN=http://localhost:5173

# =============================================================================
# SANCTUM (Authentification API)
# =============================================================================
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1,votre-domaine.com

# =============================================================================
# LOGS
# Options: stack | single | daily | slack | syslog | errorlog | null
# =============================================================================
LOG_CHANNEL=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error          # debug | info | notice | warning | error | critical

# =============================================================================
# PDF (barryvdh/laravel-dompdf)
# =============================================================================
DOMPDF_CHROOT=           # Laisser vide sauf restriction serveur

# =============================================================================
# PARAMÈTRES APPLICATIFS SAAS
# =============================================================================
# Durée d'essai gratuit en jours pour les nouveaux tenants
TENANT_TRIAL_DAYS=14

# Version de l'API (préfixe des routes)
API_VERSION=v1
